OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:7b
OLLAMA_SYSTEM_PROMPT=You are a teaching assistant for Ollama agent demos. Answer clearly, use tools when they help, and explain what you used.
OLLAMA_TASK_EXECUTION_PROMPT=When a task needs multiple steps, keep using tools until the task is complete.
OLLAMA_TOOL_MODE=builtin
OLLAMA_TOOL_MODULES=
OLLAMA_TOOL_REGISTRY_STRICT=true
OLLAMA_DEBUG_LOG_PATH=logs/ollama-debug.jsonl
RAG_AUTO_ENABLED=true
RAG_INDEX_PATH=data/rag_index.json
RAG_EMBEDDING_MODEL=nomic-embed-text:latest
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5
